// Entry point compiled by build.rs. Holds the Settings window shell (sidebar nav +
// content area) and wires each tab to a page component from its own file. The
// Onboarding window and the shared Backdrop live in their own files too. Rust
// (`windows_ui.rs`) sets the `in`/`in-out` properties and handles the callbacks.

import { Palette, ScrollView } from "std-widgets.slint";
import { Theme, AppEntry, ShortcutEntry } from "theme.slint";
import { Backdrop } from "backdrop.slint";
import { InputPage } from "page_input.slint";
import { KeyboardPage } from "page_keyboard.slint";
import { SmartPage } from "page_smart.slint";
import { ShortcutsPage } from "page_shortcuts.slint";
import { AppsPage } from "page_apps.slint";
import { GeneralPage } from "page_general.slint";
import { AboutPage } from "page_about.slint";
import { OnboardingWindow } from "onboarding.slint";
import { Compose } from "compose.slint";

export { AppEntry, ShortcutEntry, OnboardingWindow, Compose }

export component SettingsWindow inherits Window {
    title: "Funput — Cài đặt";
    icon: @image-url("../../../assets/logo.png");
    width: 720px;
    height: 480px;
    background: Theme.window-base;

    // --- state from Rust ---
    in property <string> method;
    in property <string> tone-style;
    in property <string> hotkey;
    in property <[string]> hotkey-caps;
    in-out property <bool> smart-restore;
    in-out property <bool> eager-restore;
    in-out property <bool> spell-check;
    in-out property <bool> auto-capitalize;
    in-out property <bool> launch-at-login;
    in property <[AppEntry]> excluded-apps;
    in property <[AppEntry]> recent-apps;
    in property <[ShortcutEntry]> shortcuts;
    in property <string> version;
    // Auto-update: idle | checking | uptodate | available | downloading | ready | error
    in property <string> update-state: "idle";
    in property <string> update-version;
    in property <string> update-message;

    // --- events to Rust ---
    callback pick-method(string);
    callback pick-tone(string);
    callback pick-hotkey(string);
    callback set-smart(bool);
    callback set-eager(bool);
    callback set-spell(bool);
    callback set-auto-cap(bool);
    callback set-launch(bool);
    callback add-app(string);
    callback remove-app(string);
    callback add-shortcut();
    callback remove-shortcut(int);
    callback edit-trigger(int, string);
    callback edit-expansion(int, string);
    callback open-link(string);
    callback check-update();
    callback install-update();
    callback relaunch-now();

    // `in-out` so the tray's "Kiểm tra cập nhật…" can jump straight to the About tab.
    in-out property <string> active: "input";
    property <[{id: string, label: string, icon: image}]> nav: [
        { id: "input", label: "Kiểu gõ", icon: @image-url("icons/keyboard.svg") },
        { id: "keyboard", label: "Phím chuyển", icon: @image-url("icons/switch.svg") },
        { id: "smart", label: "Thông minh", icon: @image-url("icons/sparkles.svg") },
        { id: "shortcuts", label: "Gõ tắt", icon: @image-url("icons/shortcut.svg") },
        { id: "apps", label: "Ứng dụng", icon: @image-url("icons/apps.svg") },
        { id: "general", label: "Chung", icon: @image-url("icons/settings.svg") },
        { id: "about", label: "Giới thiệu", icon: @image-url("icons/info.svg") },
    ];

    Backdrop { }

    HorizontalLayout {
        spacing: 0px;

        // ---- Sidebar ----
        Rectangle {
            width: 200px;
            background: Theme.sidebar-bg;
            border-width: 1px;
            border-color: Theme.sidebar-border;
            VerticalLayout {
                padding: Theme.sp-md;
                spacing: 2px;
                alignment: start;
                Text {
                    text: "Funput";
                    font-size: 14px;
                    font-weight: 700;
                    color: Palette.foreground;
                }
                Rectangle { height: Theme.sp-md; }
                for item in root.nav: Rectangle {
                    height: 36px;
                    border-radius: Theme.r-control;
                    background: root.active == item.id
                        ? Theme.accent
                        : (nav-touch.has-hover ? Theme.nav-hover : transparent);
                    HorizontalLayout {
                        padding-left: 12px;
                        spacing: 10px;
                        alignment: start;
                        // Wrap in a centring column so the fixed-size icon lines up
                        // vertically with the label instead of sitting at the top.
                        VerticalLayout {
                            alignment: center;
                            Image {
                                source: item.icon;
                                colorize: root.active == item.id ? Theme.accent-text : Palette.foreground;
                                width: 17px;
                                height: 17px;
                            }
                        }
                        Text {
                            text: item.label;
                            vertical-alignment: center;
                            font-size: 13px;
                            font-weight: root.active == item.id ? 600 : 400;
                            color: root.active == item.id ? Theme.accent-text : Palette.foreground;
                        }
                    }
                    nav-touch := TouchArea {
                        clicked => {
                            root.active = item.id;
                        }
                    }
                }
            }
        }

        // ---- Content: one page component per tab ----
        ScrollView {
            VerticalLayout {
                padding: Theme.sp-xl;
                spacing: Theme.sp-md;
                alignment: start;

                if root.active == "input": InputPage {
                    method: root.method;
                    tone-style: root.tone-style;
                    pick-method(v) => { root.pick-method(v); }
                    pick-tone(v) => { root.pick-tone(v); }
                }

                if root.active == "keyboard": KeyboardPage {
                    hotkey: root.hotkey;
                    hotkey-caps: root.hotkey-caps;
                    pick-hotkey(v) => { root.pick-hotkey(v); }
                }

                if root.active == "smart": SmartPage {
                    smart-restore <=> root.smart-restore;
                    eager-restore <=> root.eager-restore;
                    spell-check <=> root.spell-check;
                    auto-capitalize <=> root.auto-capitalize;
                    set-smart(v) => { root.set-smart(v); }
                    set-eager(v) => { root.set-eager(v); }
                    set-spell(v) => { root.set-spell(v); }
                    set-auto-cap(v) => { root.set-auto-cap(v); }
                }

                if root.active == "shortcuts": ShortcutsPage {
                    shortcuts: root.shortcuts;
                    add-shortcut() => { root.add-shortcut(); }
                    remove-shortcut(i) => { root.remove-shortcut(i); }
                    edit-trigger(i, t) => { root.edit-trigger(i, t); }
                    edit-expansion(i, t) => { root.edit-expansion(i, t); }
                }

                if root.active == "apps": AppsPage {
                    excluded-apps: root.excluded-apps;
                    recent-apps: root.recent-apps;
                    add-app(id) => { root.add-app(id); }
                    remove-app(id) => { root.remove-app(id); }
                }

                if root.active == "general": GeneralPage {
                    launch-at-login <=> root.launch-at-login;
                    set-launch(v) => { root.set-launch(v); }
                }

                if root.active == "about": AboutPage {
                    version: root.version;
                    update-state: root.update-state;
                    update-version: root.update-version;
                    update-message: root.update-message;
                    open-link(url) => { root.open-link(url); }
                    check-update() => { root.check-update(); }
                    install-update() => { root.install-update(); }
                    relaunch-now() => { root.relaunch-now(); }
                }
            }
        }
    }
}
